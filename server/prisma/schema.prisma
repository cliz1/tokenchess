datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  username   String    @unique
  password   String
  drafts     Draft[]   @relation("owner_drafts")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  gamesAsWhite  Game[]  @relation("white_games")
  gamesAsBlack  Game[]  @relation("black_games")
}

model Draft {
  id         String   @id @default(uuid())
  user       User     @relation("owner_drafts", fields: [userId], references: [id])
  userId     String
  name       String
  data       Json
  isPublic   Boolean  @default(false)
  isActive   Boolean  @default(false)
  slot       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Game {
  id          String   @id @default(uuid())
  whiteId     String
  blackId     String
  white       User     @relation("white_games", fields: [whiteId], references: [id])
  black       User     @relation("black_games", fields: [blackId], references: [id])
  result      String   // e.g. "Checkmate: 1-0"
  pgn         String
  startFen    String
  timeControl String   // e.g. "10+0"
  playedAt    DateTime @default(now())

  @@index([whiteId])
  @@index([blackId])
}


